{% comment %}
  SEO Structured Data for cozybooknook.store
  JSON-LD schema for better Google search results
  Optimized for "booknook" keyword trending
{% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "BookNook Store",
  "alternateName": ["Cozy Book Nook", "booknook.store", "cozybooknook"],
  "url": "https://cozybooknook.store/",
  "description": "BookNook Store - Your destination for magical booknooks, bookshelf inserts, and miniature dioramas. Transform your bookshelf into enchanting worlds with our premium booknook collection.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://cozybooknook.store/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "BookNook Store",
  "alternateName": "Cozy Book Nook",
  "description": "BookNook Store - Shop the best booknooks and bookshelf inserts online. Transform your bookshelf into magical miniature worlds. Premium quality booknooks for book lovers and collectors.",
  "url": "https://cozybooknook.store/",
  "logo": "https://cozybooknook.store{{ settings.logo | image_url: width: 500 }}",
  "image": "https://cozybooknook.store{{ page_image | image_url: width: 1200 }}",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "{{ shop.address.country_code | default: 'US' }}"
  },
  "sameAs": [
    "https://web.facebook.com/profile.php?id=61587982093817",
    "https://www.instagram.com/cozyb0oknook",
    "https://www.pinterest.com/Cozyb0oknook"
  ],
  "openingHours": "Mo-Su 00:00-24:00",
  "currenciesAccepted": "{{ cart.currency.iso_code }}",
  "paymentAccepted": "Credit Card, PayPal, Apple Pay, Google Pay",
  "slogan": "Transform Your Bookshelf Into Magic"
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BookNook Store",
  "alternateName": "Cozy Book Nook",
  "url": "https://cozybooknook.store/",
  "logo": "https://cozybooknook.store{{ settings.logo | image_url: width: 500 }}",
  "sameAs": [
    "https://web.facebook.com/profile.php?id=61587982093817",
    "https://www.instagram.com/cozyb0oknook",
    "https://www.pinterest.com/Cozyb0oknook"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": "English"
  }
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncatewords: 50 | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      "https:{{ image | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: 'Cozy Book Nook' | json }}
  },
  "category": {{ product.type | default: 'Book Nook' | json }},
  "offers": {
    "@type": "Offer",
    "url": "https://cozybooknook.store{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": "{{ product.price | money_without_currency | replace: ',', '' }}",
    "priceValidUntil": "{{ 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": "Cozy Book Nook"
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "US"
      }
    }
  }
  {%- if product.selected_or_first_available_variant.sku != blank -%}
  ,"sku": {{ product.selected_or_first_available_variant.sku | json }}
  {%- endif -%}
  {%- if product.selected_or_first_available_variant.barcode.size == 12 -%}
  ,"gtin12": "{{ product.selected_or_first_available_variant.barcode }}"
  {%- endif -%}
  {%- if product.selected_or_first_available_variant.barcode.size == 13 -%}
  ,"gtin13": "{{ product.selected_or_first_available_variant.barcode }}"
  {%- endif -%}
}
</script>
{%- endif -%}

{%- if request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "description": {{ collection.description | strip_html | truncatewords: 50 | default: 'Explore our collection of book nooks and bookshelf inserts.' | json }},
  "url": "https://cozybooknook.store{{ collection.url }}",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for product in collection.products limit: 10 -%}
        {
          "@type": "ListItem",
          "position": {{ forloop.index }},
          "item": {
            "@type": "Product",
            "name": {{ product.title | json }},
            "url": "https://cozybooknook.store{{ product.url }}",
            "image": "https:{{ product.featured_image | image_url: width: 500 }}",
            "offers": {
              "@type": "Offer",
              "priceCurrency": "{{ cart.currency.iso_code }}",
              "price": "{{ product.price | money_without_currency | replace: ',', '' }}",
              "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
            }
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
}
</script>
{%- endif -%}

{%- if request.page_type == 'article' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ article.title | json }},
  "description": {{ article.excerpt | default: article.content | strip_html | truncatewords: 30 | json }},
  "image": {%- if article.image -%}"https:{{ article.image | image_url: width: 1200 }}"{%- else -%}"https://cozybooknook.store{{ page_image | image_url: width: 1200 }}"{%- endif -%},
  "author": {
    "@type": "Person",
    "name": {{ article.author | default: 'Cozy Book Nook Team' | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": "Cozy Book Nook",
    "logo": {
      "@type": "ImageObject",
      "url": "https://cozybooknook.store{{ settings.logo | image_url: width: 500 }}"
    }
  },
  "datePublished": "{{ article.published_at | date: '%Y-%m-%d' }}",
  "dateModified": "{{ article.updated_at | date: '%Y-%m-%d' }}"
}
</script>
{%- endif -%}

{% comment %} BreadcrumbList schema for all pages {% endcomment %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://cozybooknook.store/"
    }
    {%- if request.page_type == 'product' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.type | default: 'Products' | json }},
      "item": "https://cozybooknook.store/collections/all"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "https://cozybooknook.store{{ product.url }}"
    }
    {%- elsif request.page_type == 'collection' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ collection.title | json }},
      "item": "https://cozybooknook.store{{ collection.url }}"
    }
    {%- elsif request.page_type == 'article' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "https://cozybooknook.store/blogs/news"
    }
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": {{ article.title | json }},
      "item": "https://cozybooknook.store{{ article.url }}"
    }
    {%- endif -%}
  ]
}
</script>
