{% doc %}
  Product Reviews

  Renders the product reviews section on the product page.
  Displays star ratings and review count from product metafields.

  @param {object} product - The product object

  @example
  {% render 'product-reviews', product: product %}
{% enddoc %}

{% liquid
  assign rating = product.metafields.reviews.rating.value.rating
  assign scale_max = product.metafields.reviews.rating.value.scale_max
  assign rating_count = product.metafields.reviews.rating_count
%}

{%- if rating != blank and rating_count != blank -%}
  {% liquid
    assign star_count_rating = scale_max | default: 5
    assign decimal_rating = 0
    assign decimal = rating | modulo: 1

    if decimal >= 0.3 and decimal <= 0.7
      assign decimal_rating = 0.5
    elsif decimal > 0.7
      assign decimal_rating = 1
    endif

    assign decimal_rounded = decimal_rating | ceil
    assign svg_filled_stars = rating | floor | plus: decimal_rounded
  %}

  <div class="product-reviews" data-product-reviews>
    <svg
      class="visually-hidden"
      style="width: 0; height: 0;"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      role="presentation"
    >
      <defs>
        <linearGradient id="half-star-gradient" x1="0" x2="100%" y1="0" y2="0">
          <stop offset="50%" stop-color="var(--star-fill-color)"></stop>
          <stop offset="50%" stop-color="rgb(var(--star-fill-color-rgb) / var(--opacity-20))"></stop>
        </linearGradient>

        <symbol xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" id="star-symbol">
          <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z" />
        </symbol>
      </defs>
    </svg>

    <div
      class="rating rating-color--primary"
      style="--star-size: 1.2em;"
      aria-label="{{ 'accessibility.rating' | t: rating: rating }}"
    >
      {%- for star in (1..star_count_rating) -%}
        <svg
          class="stars {% if star <= svg_filled_stars %}filled-star{% endif %}"
          viewBox="0 0 32 32"
          style="--empty-star-fill-color: rgb(var(--star-fill-color-rgb) / var(--opacity-20))"
          role="presentation"
        >
          <use xlink:href="#star-symbol"{% if decimal_rating == 0.5 and star == svg_filled_stars %} fill="url(#half-star-gradient)"{% endif %}></use>
        </svg>
      {%- endfor -%}
    </div>

    <p class="rating-count caption">
      <span class="rating-value">{{ rating | round: 1 }}</span>
      <span class="rating-count-separator">|</span>
      <span class="rating-total">{{ rating_count }} {{ 'content.reviews' | t }}</span>
    </p>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-reviews {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    margin-top: var(--gap-xs);
  }

  .rating-color--primary {
    --star-fill-color: var(--color-primary);
    --star-fill-color-rgb: var(--color-primary-rgb);
    --color: var(--color-primary);
  }

  .rating {
    display: flex;
    align-items: center;
    gap: var(--gap-3xs);
  }

  .stars {
    height: var(--star-size);
    fill: var(--empty-star-fill-color);
  }

  .filled-star {
    fill: var(--star-fill-color);
  }

  .product-reviews .rating-count {
    margin: 0;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .rating-count-separator {
    opacity: var(--opacity-20);
    padding-left: calc(var(--padding-xs) / 2);
    padding-right: var(--padding-xs);
  }
{% endstylesheet %}