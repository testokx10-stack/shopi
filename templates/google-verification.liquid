{% comment %}
  Google Search Console Verification Template
  Usage: Create a page in Shopify admin using this template
  Then submit your sitemap to Google Search Console
  
  Instructions:
  1. Go to Online Store > Pages > Add page
  2. Set the page handle to match your Google verification code
  3. Select this template from the theme template dropdown
  4. Publish the page
  
  Alternative: Add the meta tag directly in theme.liquid head section
  <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE">
{% endcomment %}

{%- layout none -%}
google-site-verification: YOUR_VERIFICATION_CODE_HERE
