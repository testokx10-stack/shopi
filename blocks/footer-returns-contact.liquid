{%- comment -%}
  Footer Returns & Contact Block
  Displays 30-Day Returns guarantee and Contact/Social information
{%- endcomment -%}

<div class="footer-returns-contact" {{ block.shopify_attributes }}>
  {%- if block.settings.show_returns -%}
    <div class="footer-returns">
      <div class="footer-returns__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="1 4 1 10 7 10"></polyline>
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
        </svg>
      </div>
      <div class="footer-returns__content">
        <span class="footer-returns__title">{{ block.settings.returns_title }}</span>
        <span class="footer-returns__text">{{ block.settings.returns_text }}</span>
      </div>
    </div>
  {%- endif -%}

  {%- if block.settings.show_contact -%}
    <div class="footer-contact">
      <div class="footer-contact__heading">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <span>{{ block.settings.contact_heading }}</span>
      </div>
      <p class="footer-contact__text">{{ block.settings.contact_text }}</p>
      <a href="{{ block.settings.contact_link }}" class="footer-contact__link">
        {{ block.settings.contact_link_text }}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      {%- if block.settings.show_social -%}
        <div class="footer-contact__social">
          <span class="footer-contact__social-label">{{ block.settings.social_label }}</span>
          <div class="footer-contact__social-links">
            {%- if block.settings.instagram_url != blank -%}
              <a href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              </a>
            {%- endif -%}
            {%- if block.settings.facebook_url != blank -%}
              <a href="{{ block.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              </a>
            {%- endif -%}
            {%- if block.settings.twitter_url != blank -%}
              <a href="{{ block.settings.twitter_url }}" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                </svg>
              </a>
            {%- endif -%}
            {%- if block.settings.tiktok_url != blank -%}
              <a href="{{ block.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .footer-returns-contact {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-returns {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px;
    background: linear-gradient(135deg, rgba(139, 90, 43, 0.08) 0%, rgba(205, 133, 63, 0.06) 100%);
    border-radius: 12px;
    border: 1px solid rgba(139, 90, 43, 0.15);
  }

  .footer-returns__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #8b5a2b 0%, #a0522d 50%, #cd853f 100%);
    border-radius: 50%;
    color: #fef9f3;
  }

  .footer-returns__icon svg {
    width: 20px;
    height: 20px;
  }

  .footer-returns__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer-returns__title {
    font-family: 'Merriweather', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #3d2314;
  }

  .footer-returns__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #5c4033;
    line-height: 1.4;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-contact__heading {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Merriweather', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    color: #3d2314;
  }

  .footer-contact__heading svg {
    width: 20px;
    height: 20px;
    color: #8b5a2b;
  }

  .footer-contact__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #5c4033;
    line-height: 1.6;
    margin: 0;
  }

  .footer-contact__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #8b5a2b;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact__link:hover {
    color: #5c4033;
  }

  .footer-contact__link svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .footer-contact__link:hover svg {
    transform: translateX(4px);
  }

  .footer-contact__social {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .footer-contact__social-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #5c4033;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-contact__social-links {
    display: flex;
    gap: 12px;
  }

  .footer-contact__social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(139, 90, 43, 0.1);
    color: #8b5a2b;
    transition: all 0.2s ease;
  }

  .footer-contact__social-links a:hover {
    background: #8b5a2b;
    color: #fef9f3;
    transform: translateY(-2px);
  }

  .footer-contact__social-links svg {
    width: 18px;
    height: 18px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Returns & Contact",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "30-Day Returns Section"
    },
    {
      "type": "checkbox",
      "id": "show_returns",
      "label": "Show returns guarantee",
      "default": true
    },
    {
      "type": "text",
      "id": "returns_title",
      "label": "Returns title",
      "default": "30-Day Returns"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns description",
      "default": "Hassle-free guarantee"
    },
    {
      "type": "header",
      "content": "Contact Section"
    },
    {
      "type": "checkbox",
      "id": "show_contact",
      "label": "Show contact section",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Get in Touch"
    },
    {
      "type": "textarea",
      "id": "contact_text",
      "label": "Contact description",
      "default": "Have questions? We'd love to hear from you. Reach out to our friendly team for personalized assistance."
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact page link"
    },
    {
      "type": "text",
      "id": "contact_link_text",
      "label": "Contact link text",
      "default": "Contact Us"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "Social links label",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "presets": [
    {
      "name": "Returns & Contact",
      "category": "Footer"
    }
  ]
}
{% endschema %}
