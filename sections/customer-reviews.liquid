{% comment %}
  Customer Reviews Section
  
  Displays stylized customer review cards with star ratings.
  Online Store 2.0 compatible section.
{% endcomment %}

<div class="customer-reviews-section color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="section-header">
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="section-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}
    
    <div class="reviews-grid">
      {% for block in section.blocks %}
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="review-card review-card--linked" {{ block.shopify_attributes }}>
        {% else %}
          <div class="review-card" {{ block.shopify_attributes }}>
        {% endif %}
          <div class="review-stars">
              {% assign rating = block.settings.rating %}
              {% for i in (1..5) %}
                {% if i <= rating %}
                  <svg class="star star--filled" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                {% else %}
                  <svg class="star star--empty" viewBox="0 0 20 20" fill="#e0e0e0">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                {% endif %}
              {% endfor %}
            </div>
          
          {% if block.settings.review_text != blank %}
            <p class="review-text">"{{ block.settings.review_text }}"</p>
          {% endif %}
          
          <div class="review-author">
            {% if block.settings.author_image != blank %}
              <img src="{{ block.settings.author_image }}" alt="{{ block.settings.author_name }}" class="author-avatar" width="48" height="48" />
            {% endif %}
            {% if block.settings.author_name != blank %}
              <span class="author-name">~ {{ block.settings.author_name }}</span>
            {% endif %}
            {% if block.settings.verified %}
              <span class="verified-badge">Verified Buyer</span>
            {% endif %}
          </div>
          
          {% if block.settings.product_name != blank %}
            <div class="review-product">
              <span class="product-label">Product:</span>
              <span class="product-name">{{ block.settings.product_name }}</span>
            </div>
          {% endif %}
        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .customer-reviews-section {
    padding: 60px 20px;
  }
  
  .customer-reviews-section .section-header {
    text-align: center;
    margin-bottom: 40px;
  }
  
  .customer-reviews-section .section-heading {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 10px;
    color: var(--color-foreground);
  }
  
  .customer-reviews-section .section-subheading {
    font-size: 1.1rem;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    margin: 0;
  }
  
  .customer-reviews-section .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  
  @media screen and (max-width: 989px) {
    .customer-reviews-section .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (max-width: 749px) {
    .customer-reviews-section .reviews-grid {
      grid-template-columns: 1fr;
    }
    
    .customer-reviews-section .section-heading {
      font-size: 1.8rem;
    }
  }
  
  .customer-reviews-section .review-card {
    background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .customer-reviews-section .review-card::before {
    content: '"';
    position: absolute;
    top: 10px;
    right: 20px;
    font-size: 80px;
    font-family: Georgia, serif;
    color: rgba(0, 0, 0, 0.05);
    line-height: 1;
  }
  
  .customer-reviews-section .review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }
  
  .customer-reviews-section .review-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 16px;
  }
  
  .customer-reviews-section .star {
    width: 18px;
    height: 18px;
    color: #ffc107;
  }
  
  .customer-reviews-section .star--filled {
    color: #ffc107;
  }
  
  .customer-reviews-section .star--empty {
    color: #e0e0e0;
  }
  
  .customer-reviews-section .review-text {
    font-size: 1rem;
    line-height: 1.6;
    color: #333;
    margin: 0 0 16px;
    font-style: italic;
  }
  
  .customer-reviews-section .review-author {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  
  .customer-reviews-section .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #e0e0e0;
  }
  
  .customer-reviews-section .author-name {
    font-weight: 600;
    color: #555;
    font-size: 0.95rem;
  }
  
  .customer-reviews-section .verified-badge {
    background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
    color: white;
    font-size: 0.7rem;
    padding: 3px 8px;
    border-radius: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .customer-reviews-section .review-product {
    padding-top: 12px;
    border-top: 1px solid #eee;
    font-size: 0.85rem;
  }
  
  .customer-reviews-section .product-label {
    color: #888;
    margin-right: 5px;
  }
  
  .customer-reviews-section .product-name {
    color: #666;
    font-weight: 500;
  }
  
  .customer-reviews-section .review-card--linked {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    display: block;
  }
  
  .customer-reviews-section .review-card--linked:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section-customer-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from happy customers"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "This product exceeded my expectations! The quality is amazing and it looks even better in person."
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "url",
          "id": "author_image",
          "label": "Author image URL"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "Book Nook Kit"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Absolutely stunning! The attention to detail is incredible. It transformed my bookshelf into a magical scene.",
            "author_name": "Emma T.",
            "verified": true,
            "product_name": "Magical Forest Book Nook",
            "link": ""
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Best purchase I've made this year! The quality exceeded my expectations and assembly was so fun.",
            "author_name": "Michael R.",
            "verified": true,
            "product_name": "Cozy Cottage Diorama",
            "link": ""
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "A perfect gift for any book lover! The craftsmanship is beautiful and it arrived quickly.",
            "author_name": "Jessica L.",
            "verified": true,
            "product_name": "Enchanted Garden Kit",
            "link": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}